# =============================================================================
# UrbanPulse — .gitignore
# =============================================================================
# Rules are ordered from broadest (Python / tooling) to project-specific.
# Generated pipeline artifacts are excluded; source code and schema are tracked.
# =============================================================================


# ---------------------------------------------------------------------------
# Python bytecode & caches
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyo

# ---------------------------------------------------------------------------
# Testing & coverage
# ---------------------------------------------------------------------------
.pytest_cache/
.coverage
.coverage.*
coverage.xml
htmlcov/
*.hypothesis/

# ---------------------------------------------------------------------------
# Virtual environments
# ---------------------------------------------------------------------------
.venv/
venv/
env/
ENV/
.env

# ---------------------------------------------------------------------------
# Packaging / build artifacts
# ---------------------------------------------------------------------------
dist/
build/
*.egg-info/
*.egg
MANIFEST
wheels/
*.whl

# # ---------------------------------------------------------------------------
# # Jupyter
# # ---------------------------------------------------------------------------
# # Keep notebooks in source control (they document findings).
# # Ignore only execution-time outputs that bloat diffs.
# .ipynb_checkpoints/
# *.ipynb_checkpoints

# ---------------------------------------------------------------------------
# IDE & editor noise
# ---------------------------------------------------------------------------
.vscode/
.idea/
*.suo
*.user
*.sln.docstash
Thumbs.db
Desktop.ini
.DS_Store

# ---------------------------------------------------------------------------
# Windows OS noise
# ---------------------------------------------------------------------------
[Dd]esktop.ini
$RECYCLE.BIN/
*.lnk

# # ---------------------------------------------------------------------------
# # Data — raw input (large, re-downloadable, never committed)
# # ---------------------------------------------------------------------------
data/raw.csv
data/*.csv          # any raw / intermediate CSV dumps in data/
# Re-allow the small norms JSON (it is source-controlled as it documents
# training-time normalization constants needed at inference).
!data/feature_norms.json

# ---------------------------------------------------------------------------
# Data — pipeline artifacts (large binary, fully reproducible by re-running)
# ---------------------------------------------------------------------------
data/cleaned.parquet
data/features.parquet 

models/*.pkl 

# # ---------------------------------------------------------------------------
# # Trained model binaries (large, reproducible by re-running train.py)
# # ---------------------------------------------------------------------------
models/
!models/.gitkeep

# # ---------------------------------------------------------------------------
# # SHAP artifacts (generated by B5 — reproducible)
# # ---------------------------------------------------------------------------
# reports/shap/

# ---------------------------------------------------------------------------
# Report images and CSVs (generated by B1-B4 — reproducible)
# Kept: the directory structure and any hand-written analysis.
# Excluded: every generated PNG / CSV so re-runs don't create noisy diffs.
# ---------------------------------------------------------------------------
reports/eda/*.png
reports/eda/*.csv
reports/model_comparison/*.png
reports/model_comparison/*.csv
reports/model_metrics.csv
reports/no_linkid_metrics.csv

# # ---------------------------------------------------------------------------
# # SQLite database (generated by B11 — fully reproducible from schema.sql)
# # ---------------------------------------------------------------------------
db/urbanpulse.db
db/*.db
db/*.db-shm
db/*.db-wal

# # ---------------------------------------------------------------------------
# # ECHO / engine / LLM generated artifacts (B7-B10)
# # ---------------------------------------------------------------------------
data/road_archetypes.json
data/causal_graph.json
data/cascade_events.csv
data/counterfactual_results.json

# ---------------------------------------------------------------------------
# Experiment / exploratory scripts (not part of the canonical pipeline)
# ---------------------------------------------------------------------------
run_no_linkid.py
train_no_linkid.py

tests/ 
frontend/node_modules
